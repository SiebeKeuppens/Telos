# Copy to .env and fill in. VITE_AUTH_MODE=dev pairs with the server's
# AUTH_MODE=insecure-dev for local work; omit it to use real Firebase Auth.
VITE_AUTH_MODE=dev

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

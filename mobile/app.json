{
  "expo": {
    "name": "Telos",
    "slug": "telos",
    "scheme": "telos",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0a0f10",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f10"
    },
    "android": {
      "package": "online.keuppens.telos",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f10"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "online.keuppens.telos"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ],
      "react-native-health-connect",
      "./plugins/withHealthConnectDelegate",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/SpaceGrotesk_500Medium.ttf",
            "./assets/fonts/SpaceGrotesk_600SemiBold.ttf",
            "./assets/fonts/Inter_400Regular.ttf",
            "./assets/fonts/Inter_500Medium.ttf",
            "./assets/fonts/ionicons.ttf"
          ]
        }
      ]
    ]
  }
}

{
  "expo": {
    "name": "Telos",
    "slug": "telos",
    "scheme": "telos",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0f10",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f10"
    },
    "android": {
      "package": "online.keuppens.telos",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f10"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "online.keuppens.telos"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ]
  }
}

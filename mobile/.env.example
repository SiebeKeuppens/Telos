# Copy to .env and fill in. Expo inlines EXPO_PUBLIC_* vars at build time.

# Where the Go API lives. Defaults to production if unset.
#   • production:  https://telos.keuppens.online
#   • local dev:   http://<your-LAN-IP>:8080   (a phone can't reach localhost)
EXPO_PUBLIC_API_BASE=https://telos.keuppens.online

# Auth mode: "firebase" (default) or "dev".
#   "dev" sends a "dev:<uid>:<email>" bearer and needs the server running
#   AUTH_MODE=insecure-dev — handy for testing against a local backend with no
#   Firebase round-trip.
EXPO_PUBLIC_AUTH_MODE=firebase

# Firebase web config (public by design — same values as the web app, project
# travel-2d1bd). Only needed when EXPO_PUBLIC_AUTH_MODE=firebase.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
